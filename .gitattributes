# 모든 텍스트 파일을 LF로 통일 (macOS / Windows 협업 시 EOL 충돌 방지)
* text=auto eol=lf

# 명시적 텍스트 (LF 강제)
*.py        text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.json      text eol=lf
*.jsonl     text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.sh        text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
.env.example text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf

# 바이너리 (변환 금지)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.pdf       binary
*.xlsx      binary
*.xls       binary
*.parquet   binary
*.ipynb     binary
*.zip       binary
*.gz        binary
*.tar       binary
